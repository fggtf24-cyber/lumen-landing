# Скопируйте в .env и заполните. Файл .env в репозиторий не коммитится.

# Сервер
PORT=3000

# CORS: домены, которым разрешено обращаться к API (через запятую).
# Прод-сайт:
ALLOWED_ORIGINS=https://fggtf24-cyber.github.io
# Для локальной разработки можно добавить:
# ALLOWED_ORIGINS=https://fggtf24-cyber.github.io,http://localhost:8777

# --- Telegram (достаточно этого канала) ---
# Токен от @BotFather:
TELEGRAM_BOT_TOKEN=
# chat_id получателя (см. README → "Настроить Telegram-бота"):
TELEGRAM_CHAT_ID=

# --- Email по SMTP (опционально; оставьте пустым, если не нужен) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
LEAD_EMAIL_TO=fggtf24@gmail.com
